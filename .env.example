# May page — optional geofence (decimal degrees) and hero image
# Copy to .env.local for local dev. For GitHub Pages, set repository Variables
# and pass them in the workflow Build step (see .github/workflows/gh-deploy.yml).

VITE_MAY_TARGET_LAT=
VITE_MAY_TARGET_LNG=
# Radius in meters (defaults to 125 if unset or invalid)
VITE_MAY_RADIUS_M=

# Optional: full URL or path; defaults to /may-hero.svg
VITE_MAY_IMAGE_URL=https://i0.wp.com/www.glasgowwithkids.co.uk/wp-content/uploads/2025/02/the-whangie-rock-formation-scaled.jpg?ssl=1
